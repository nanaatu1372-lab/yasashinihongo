<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>にほんご LIFE — 外国人のための生活日本語</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Noto+Serif+JP:wght@400;700&family=DM+Sans:ital,wght@0,300;0,500;0,700;1,300&display=swap" rel="stylesheet">
<style>
:root {
  --bg:        #FAFAF7;
  --surface:   #FFFFFF;
  --border:    #E8E4DC;
  --text:      #1A1A18;
  --text-mid:  #555550;
  --text-soft: #888880;
  --yellow:    #F5E642;
  --yellow-d:  #C8BB00;
  --green:     #D4EDDA;
  --green-d:   #2E7D4F;
  --blue:      #D6EAF8;
  --blue-d:    #1565C0;
  --red:       #FDECEA;
  --red-d:     #C62828;
  --tag-h:     #FFF3E0;
  --tag-hd:    #E65100;
  --radius:    12px;
  --shadow:    0 2px 16px rgba(0,0,0,0.07);
  --shadow-md: 0 4px 24px rgba(0,0,0,0.10);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', 'Noto Sans JP', sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
}

/* ── HEADER ─────────────────────────────── */
header {
  background: var(--text);
  padding: 0 24px;
  position: sticky; top: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  height: 56px;
  border-bottom: 3px solid var(--yellow);
}
.logo {
  font-family: 'Noto Serif JP', serif;
  font-weight: 700;
  font-size: 20px;
  color: var(--yellow);
  letter-spacing: 0.02em;
}
.logo span { color: #fff; font-weight: 300; font-size: 14px; margin-left: 8px; vertical-align: middle; }
.lang-btns { display: flex; gap: 6px; }
.lang-btn {
  background: transparent;
  border: 1px solid rgba(255,255,255,0.3);
  color: rgba(255,255,255,0.7);
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 12px;
  cursor: pointer;
  transition: all .2s;
}
.lang-btn.active, .lang-btn:hover { background: var(--yellow); border-color: var(--yellow); color: var(--text); }

/* ── NAV TABS ────────────────────────────── */
.nav-tabs {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex;
  overflow-x: auto;
  scrollbar-width: none;
  padding: 0 16px;
  gap: 0;
  position: sticky; top: 56px; z-index: 90;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}
.nav-tabs::-webkit-scrollbar { display: none; }
.tab-btn {
  flex-shrink: 0;
  padding: 14px 20px;
  border: none;
  background: transparent;
  font-size: 14px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 500;
  color: var(--text-soft);
  cursor: pointer;
  border-bottom: 3px solid transparent;
  transition: all .2s;
  white-space: nowrap;
  display: flex; align-items: center; gap: 6px;
}
.tab-btn:hover { color: var(--text); background: var(--bg); }
.tab-btn.active { color: var(--text); border-bottom-color: var(--yellow); }
.tab-btn .emoji { font-size: 18px; }

/* ── MAIN LAYOUT ─────────────────────────── */
main { max-width: 960px; margin: 0 auto; padding: 24px 16px 60px; }
.section { display: none; }
.section.active { display: block; }

/* ── SECTION HEADER ──────────────────────── */
.sec-header {
  display: flex; align-items: center; gap: 14px;
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 2px solid var(--border);
}
.sec-icon {
  width: 52px; height: 52px;
  background: var(--yellow);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px;
  flex-shrink: 0;
}
.sec-title { font-family: 'Noto Serif JP', serif; font-size: 22px; font-weight: 700; }
.sec-sub { font-size: 13px; color: var(--text-soft); margin-top: 2px; }

/* ── SITUATION CARD ──────────────────────── */
.situation-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media (max-width: 600px) { .situation-grid { grid-template-columns: 1fr; } }

.situation-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: transform .2s, box-shadow .2s;
}
.situation-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
.card-header {
  padding: 14px 16px;
  display: flex; align-items: center; gap: 10px;
  border-bottom: 1px solid var(--border);
}
.card-icon { font-size: 22px; }
.card-title { font-weight: 700; font-size: 15px; }
.card-sub { font-size: 12px; color: var(--text-soft); }

/* ── DIALOGUE BLOCK ──────────────────────── */
.dialogue-block { padding: 0 16px 16px; }
.dialogue-row {
  display: flex;
  gap: 10px;
  margin-top: 12px;
  align-items: flex-start;
}
.dialogue-row.right { flex-direction: row-reverse; }

.bubble-wrap { max-width: 80%; }
.speaker-label {
  font-size: 11px;
  color: var(--text-soft);
  margin-bottom: 3px;
  font-weight: 500;
}
.dialogue-row.right .speaker-label { text-align: right; }
.bubble {
  padding: 10px 14px;
  border-radius: 16px;
  font-size: 14px;
  line-height: 1.65;
}
.bubble-jp {
  background: #F0F0EC;
  border-radius: 16px 16px 16px 4px;
  color: var(--text);
}
.dialogue-row.right .bubble-jp {
  background: #E8F4FD;
  border-radius: 16px 16px 4px 16px;
}
.bubble-ruby {
  font-size: 11px;
  color: var(--text-soft);
  margin-top: 2px;
  font-style: italic;
}
.bubble-en {
  font-size: 12px;
  color: var(--text-soft);
  margin-top: 3px;
}
.key-phrase {
  background: var(--yellow);
  padding: 1px 5px;
  border-radius: 4px;
  font-weight: 700;
}

/* ── VOCAB TABLE ─────────────────────────── */
.vocab-section { margin-top: 24px; }
.vocab-section h3 {
  font-size: 14px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .08em;
  color: var(--text-soft);
  margin-bottom: 12px;
  display: flex; align-items: center; gap: 8px;
}
.vocab-section h3::after { content:''; flex:1; height:1px; background:var(--border); }
.vocab-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 10px;
}
.vocab-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 14px;
  cursor: pointer;
  transition: all .2s;
  position: relative;
}
.vocab-card:hover { border-color: var(--yellow); box-shadow: 0 0 0 3px rgba(245,230,66,0.2); }
.vocab-jp { font-size: 20px; font-weight: 700; font-family: 'Noto Serif JP', serif; }
.vocab-ruby { font-size: 11px; color: var(--text-soft); }
.vocab-en { font-size: 13px; color: var(--text-mid); margin-top: 4px; }
.vocab-tag {
  position: absolute; top: 10px; right: 10px;
  font-size: 10px; padding: 2px 7px;
  border-radius: 20px;
  font-weight: 700; letter-spacing: .05em;
}
.tag-n { background: var(--blue); color: var(--blue-d); }
.tag-v { background: var(--green); color: var(--green-d); }
.tag-adj { background: var(--tag-h); color: var(--tag-hd); }
.tag-exp { background: var(--red); color: var(--red-d); }

/* ── GRAMMAR POINT ───────────────────────── */
.grammar-list { display: flex; flex-direction: column; gap: 16px; margin-top: 8px; }
.grammar-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 4px solid var(--yellow);
  border-radius: var(--radius);
  padding: 16px 18px;
  box-shadow: var(--shadow);
}
.grammar-pattern {
  font-family: 'Noto Serif JP', serif;
  font-size: 18px; font-weight: 700;
  color: var(--text);
  margin-bottom: 6px;
}
.grammar-en { font-size: 13px; color: var(--text-soft); margin-bottom: 10px; }
.grammar-example {
  background: var(--bg);
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 14px;
  margin-top: 8px;
}
.grammar-example .jp { font-weight: 500; }
.grammar-example .ruby { font-size: 11px; color: var(--text-soft); }
.grammar-example .en { font-size: 12px; color: var(--text-soft); margin-top: 2px; font-style: italic; }

/* ── QUIZ ────────────────────────────────── */
.quiz-wrap { margin-top: 8px; }
.quiz-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: var(--shadow);
}
.quiz-q { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
.quiz-q-en { font-size: 13px; color: var(--text-soft); margin-bottom: 14px; }
.quiz-options { display: flex; flex-direction: column; gap: 8px; }
.quiz-opt {
  padding: 10px 16px;
  border: 2px solid var(--border);
  border-radius: 10px;
  cursor: pointer;
  font-size: 14px;
  transition: all .2s;
  background: var(--bg);
  text-align: left;
  display: flex; gap: 10px; align-items: center;
}
.quiz-opt:hover { border-color: var(--yellow); background: #FFFDE0; }
.quiz-opt.correct { border-color: var(--green-d); background: var(--green); color: var(--green-d); }
.quiz-opt.wrong { border-color: var(--red-d); background: var(--red); color: var(--red-d); }
.quiz-opt.disabled { cursor: default; }
.quiz-feedback {
  margin-top: 10px;
  padding: 10px 14px;
  border-radius: 8px;
  font-size: 13px;
  display: none;
}
.quiz-feedback.correct { background: var(--green); color: var(--green-d); display: block; }
.quiz-feedback.wrong { background: var(--red); color: var(--red-d); display: block; }

/* ── AUDIO BUTTON ────────────────────────── */
.audio-btn {
  display: inline-flex; align-items: center; gap: 6px;
  background: transparent;
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 5px 14px;
  font-size: 13px;
  color: var(--text-mid);
  cursor: pointer;
  transition: all .2s;
  margin-top: 8px;
  font-family: 'DM Sans', sans-serif;
}
.audio-btn:hover { border-color: var(--yellow); background: var(--yellow); color: var(--text); }
.audio-btn::before { content: '▶'; font-size: 10px; }

/* ── BADGE TAGS ──────────────────────────── */
.badge {
  display: inline-block;
  font-size: 11px; font-weight: 700;
  padding: 3px 10px; border-radius: 20px;
  margin: 2px;
}
.badge-easy { background: var(--green); color: var(--green-d); }
.badge-hard { background: var(--red); color: var(--red-d); }
.badge-polite { background: var(--blue); color: var(--blue-d); }
.badge-casual { background: var(--tag-h); color: var(--tag-hd); }

/* ── TIP BOX ─────────────────────────────── */
.tip-box {
  background: #FFFDE7;
  border: 1px solid #F9A825;
  border-radius: 10px;
  padding: 12px 16px;
  font-size: 13px;
  margin-top: 12px;
  display: flex; gap: 10px;
}
.tip-box::before { content: '💡'; flex-shrink: 0; }

/* ── SCORE BAR ───────────────────────────── */
#quiz-score-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--text);
  color: var(--yellow);
  text-align: center;
  padding: 10px;
  font-size: 14px;
  font-weight: 700;
  transform: translateY(100%);
  transition: transform .3s;
  z-index: 200;
}
#quiz-score-bar.visible { transform: translateY(0); }

/* ── HERO BANNER ─────────────────────────── */
.hero {
  background: var(--text);
  border-radius: 16px;
  padding: 28px 28px 24px;
  margin-bottom: 24px;
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: 'にほんご';
  position: absolute; right: -10px; top: -20px;
  font-family: 'Noto Serif JP', serif;
  font-size: 80px; font-weight: 900;
  color: rgba(255,255,255,0.04);
  pointer-events: none;
}
.hero h1 {
  font-family: 'Noto Serif JP', serif;
  font-size: 26px; font-weight: 700;
  color: var(--yellow);
  margin-bottom: 6px;
}
.hero p { font-size: 14px; color: rgba(255,255,255,0.65); margin-bottom: 16px; }
.hero-chips { display: flex; flex-wrap: wrap; gap: 8px; }
.hero-chip {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  color: #fff;
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 13px;
  cursor: pointer;
  transition: all .2s;
}
.hero-chip:hover, .hero-chip.active {
  background: var(--yellow);
  border-color: var(--yellow);
  color: var(--text);
}

/* ── COLLAPSE ────────────────────────────── */
details {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 10px;
  overflow: hidden;
}
summary {
  padding: 14px 16px;
  cursor: pointer;
  font-weight: 600; font-size: 15px;
  list-style: none;
  display: flex; justify-content: space-between; align-items: center;
  background: var(--surface);
}
summary::after { content: '＋'; font-size: 18px; color: var(--text-soft); }
details[open] summary::after { content: '－'; }
details > div { padding: 0 16px 16px; background: var(--surface); }

/* ── PROGRESS ────────────────────────────── */
.progress-bar-wrap { background: var(--border); border-radius: 99px; height: 6px; margin: 6px 0 16px; }
.progress-bar { background: var(--yellow); border-radius: 99px; height: 6px; transition: width .4s; }

/* ── HOSPITAL BLOCKS (tab sub-sections) ──── */
.hosp-block { display: none; margin-bottom: 8px; }
.hosp-block.active { display: block; }

/* ── DEPT HEADER ─────────────────────────── */
.dept-header {
  font-family: 'Noto Serif JP', serif;
  font-size: 17px; font-weight: 700;
  color: var(--text);
  margin-bottom: 14px;
  padding: 12px 16px;
  background: var(--surface);
  border-radius: var(--radius);
  border-left: 4px solid var(--yellow);
  box-shadow: var(--shadow);
}

/* ── DEPT GRID ───────────────────────────── */
.dept-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 12px;
  margin-bottom: 8px;
}
@media (max-width: 600px) { .dept-grid { grid-template-columns: repeat(2, 1fr); } }

.dept-card {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: 14px;
  padding: 14px 12px 12px;
  text-align: center;
  box-shadow: var(--shadow);
  transition: transform .2s, box-shadow .2s, border-color .2s;
  cursor: default;
}
.dept-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--yellow); }
.dept-icon { font-size: 28px; margin-bottom: 6px; }
.dept-jp { font-family: 'Noto Serif JP', serif; font-size: 16px; font-weight: 700; color: var(--text); }
.dept-ruby { font-size: 10px; color: var(--text-soft); margin-bottom: 4px; }
.dept-en { font-size: 11px; color: var(--text-mid); margin-bottom: 6px; line-height: 1.4; }
.dept-symptom {
  font-size: 11px;
  background: var(--yellow1, #FFFDE7);
  background: #FFFDE7;
  border-radius: 6px;
  padding: 4px 6px;
  color: #7A6800;
  line-height: 1.5;
}

/* ── INSURANCE GRID ──────────────────────── */
.insurance-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 14px;
  margin: 16px 0;
}
@media (max-width: 600px) { .insurance-grid { grid-template-columns: 1fr; } }

.insurance-card {
  border-radius: 14px;
  padding: 16px;
  box-shadow: var(--shadow);
  border: 1.5px solid transparent;
}
.ins-title {
  font-family: 'Noto Serif JP', serif;
  font-size: 15px; font-weight: 700;
  margin-bottom: 4px;
  line-height: 1.5;
}
.ins-title span { font-size: 11px; font-weight: 400; font-family: 'DM Sans', sans-serif; }
.ins-en { font-size: 12px; color: var(--text-soft); margin-bottom: 10px; font-style: italic; }
.ins-body { margin-bottom: 10px; }
.ins-point { font-size: 13px; line-height: 1.9; }
.ins-note { font-size: 11px; color: var(--text-soft); border-top: 1px solid rgba(0,0,0,0.08); padding-top: 8px; line-height: 1.5; }

.ins-blue   { background: #E3F2FD; border-color: #90CAF9; }
.ins-green  { background: #E8F5E9; border-color: #A5D6A7; }
.ins-yellow { background: #FFFDE7; border-color: #FFE082; }
.ins-orange { background: #FFF3E0; border-color: #FFCC80; }
.ins-purple { background: #F3E5F5; border-color: #CE93D8; }
.ins-red    { background: #FDECEA; border-color: #EF9A9A; }

/* ── GARBAGE SECTION ─────────────────── */
.garbage-wide { grid-column: 1 / -1; }

.garbage-type-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 10px;
  margin-bottom: 6px;
}
@media (max-width:600px) { .garbage-type-grid { grid-template-columns: repeat(2,1fr); } }

.gtype-card {
  background: var(--surface);
  border: 2px solid var(--border);
  border-radius: 12px;
  padding: 12px 10px;
  text-align: center;
}
.gtype-icon { font-size: 24px; margin-bottom: 4px; }
.gtype-jp { font-family: 'Noto Serif JP', serif; font-size: 14px; font-weight: 700; }
.gtype-ruby { font-size: 10px; color: var(--text-soft); margin-bottom: 4px; }
.gtype-en { font-size: 11px; color: var(--text-mid); margin-bottom: 6px; font-style: italic; }
.gtype-ex { font-size: 11px; color: var(--text-mid); line-height: 1.5; }
.gtype-ex-en { font-size: 10px; color: var(--text-soft); line-height: 1.4; font-style: italic; }

/* ── REGION BUTTONS ──────────────────── */
.region-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 6px 14px;
  font-size: 13px;
  font-family: 'DM Sans', sans-serif;
  cursor: pointer;
  transition: all .2s;
  color: var(--text-mid);
}
.region-btn:hover, .region-btn.active {
  background: var(--yellow);
  border-color: var(--yellow-d, #C8BB00);
  color: var(--text);
  font-weight: 700;
}

/* ── REGION INFO ─────────────────────── */
.region-info { display: none; }
.region-info.active { display: block; }

.region-name {
  font-family: 'Noto Serif JP', serif;
  font-size: 15px; font-weight: 700;
  margin-bottom: 10px;
  padding-bottom: 6px;
  border-bottom: 2px solid var(--yellow);
  display: inline-block;
}
.region-schedule { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
.sched-row {
  display: flex; align-items: center; gap: 10px;
  background: var(--bg);
  border-radius: 8px;
  padding: 8px 12px;
  font-size: 13px;
}
.sched-type {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 12px; font-weight: 700;
  white-space: nowrap;
  flex-shrink: 0;
}
.sched-day { font-size: 13px; color: var(--text-mid); }
.sched-type.burn    { background: #FFEBEE; color: #C62828; }
.sched-type.noburn  { background: #E3F2FD; color: #1565C0; }
.sched-type.recycle { background: #E8F5E9; color: #2E7D32; }
.sched-type.plastic { background: #F3E5F5; color: #6A1B9A; }
.sched-type.bulk    { background: #FFF3E0; color: #E65100; }

.region-note {
  font-size: 12px;
  background: #FFFDE7;
  border: 1px solid #F9A825;
  border-radius: 8px;
  padding: 8px 12px;
  line-height: 1.7;
  margin-bottom: 10px;
}
.region-links { display: flex; gap: 8px; flex-wrap: wrap; }
.region-link-btn {
  background: var(--blue);
  color: var(--blue-d);
  border: 1px solid var(--blueBdr, #42A5F5);
  border-radius: 6px;
  padding: 4px 12px;
  font-size: 12px;
  text-decoration: none;
  font-family: 'DM Sans', sans-serif;
  transition: all .2s;
}
.region-link-btn:hover { background: var(--blue-d); color: #fff; }
</style>
</head>
<body>

<header>
  <div class="logo">にほんご LIFE <span>外国人のための生活日本語</span></div>
  <div class="lang-btns">
    <button class="lang-btn active">JP</button>
    <button class="lang-btn">EN</button>
  </div>
</header>

<nav class="nav-tabs">
  <button class="tab-btn active" onclick="switchTab('hospital')" id="tab-hospital">
    <span class="emoji">🏥</span>病院
  </button>
  <button class="tab-btn" onclick="switchTab('city')" id="tab-city">
    <span class="emoji">🏢</span>市役所
  </button>
  <button class="tab-btn" onclick="switchTab('shop')" id="tab-shop">
    <span class="emoji">🛒</span>買い物
