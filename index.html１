        <button class="quiz-opt" onclick="answerQuiz(this,1,5)"><span>B</span>112</button>
        <button class="quiz-opt" onclick="answerQuiz(this,2,5)"><span>C</span>119</button>
        <button class="quiz-opt" onclick="answerQuiz(this,3,5)"><span>D</span>118</button>
      </div>
      <div class="quiz-feedback" id="feedback-5"></div>
    </div>

  </div><!-- end quiz-container -->

  <div style="text-align:center;margin-top:20px">
    <button onclick="resetQuiz()" style="background:var(--text);color:var(--yellow);border:none;padding:12px 28px;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">
      🔄 もう一度やる Reset Quiz
    </button>
  </div>
</section>

</main>

<div id="quiz-score-bar">⭐ スコア Score: <span id="final-score">0</span> / 6</div>

<script>
// ── TAB SWITCH ─────────────────────────
function switchTab(id) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('section-' + id).classList.add('active');
  document.getElementById('tab-' + id).classList.add('active');
}

// ── HOSPITAL SUB-TAB ───────────────────
function showHospitalTab(tab, chip) {
  chip.closest('.hero-chips').querySelectorAll('.hero-chip').forEach(c => c.classList.remove('active'));
  chip.classList.add('active');

  const blockMap = {
    all:        ['hosp-dept','hosp-reception','hosp-doctor','hosp-pharmacy','hosp-notebook','hosp-insurance','hosp-emergency','hosp-vocab-all'],
    dept:       ['hosp-dept'],
    reception:  ['hosp-reception'],
    doctor:     ['hosp-doctor'],
    pharmacy:   ['hosp-pharmacy'],
    notebook:   ['hosp-notebook'],
    insurance:  ['hosp-insurance'],
    emergency:  ['hosp-emergency'],
  };
  document.querySelectorAll('.hosp-block').forEach(b => b.classList.remove('active'));
  (blockMap[tab] || []).forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.add('active');
  });
}

// ── FILTER CARDS ──────────────────────
function filterCards(section, cat, chip) {
  chip.closest('.hero-chips').querySelectorAll('.hero-chip').forEach(c => c.classList.remove('active'));
  chip.classList.add('active');

  // グリッドのIDマッピング
  const gridId = section + '-cards';
  const grid = document.getElementById(gridId);
  if (!grid) return;

  grid.querySelectorAll('.situation-card').forEach(c => {
    if (cat === 'all' || c.dataset.cat === cat) {
      c.style.display = '';
    } else {
      c.style.display = 'none';
    }
  });
}

// ── SPEECH SYNTHESIS ──────────────────
function speak(text) {
  if ('speechSynthesis' in window) {
    window.speechSynthesis.cancel();
    const utter = new SpeechSynthesisUtterance(text);
    utter.lang = 'ja-JP';
    utter.rate = 0.85;
    const voices = window.speechSynthesis.getVoices();
    const jaVoice = voices.find(v => v.lang.startsWith('ja'));
    if (jaVoice) utter.voice = jaVoice;
    window.speechSynthesis.speak(utter);
  } else {
    alert('お使いのブラウザは音声に対応していません。\nYour browser does not support speech synthesis.');
  }
}
window.speechSynthesis && window.speechSynthesis.getVoices();

// Initialize hospital blocks (show all on load)
document.addEventListener('DOMContentLoaded', () => {
  ['hosp-dept','hosp-reception','hosp-doctor','hosp-pharmacy','hosp-notebook','hosp-insurance','hosp-emergency','hosp-vocab-all']
    .forEach(id => { const el = document.getElementById(id); if(el) el.classList.add('active'); });
});

// ── QUIZ ──────────────────────────────
let quizScore = 0;
let quizAnswered = 0;
const totalQ = 6;

const correctMessages = [
  'せいかい！ Correct! ✅ おなかが痛いです is the right answer — you describe your symptoms.',
  'せいかい！ Correct! ✅ 3 times a day (1日3回), after meals (食後) — remember this pattern!',
  'せいかい！ Correct! ✅ 在留カード and passport are required for moving-in registration.',
  'せいかい！ Correct! ✅ もう一度 = one more time. Very useful at work!',
  'せいかい！ Correct! ✅ 〜ていただけますか is a polite request — use it at hospitals and city hall!',
  'せいかい！ Correct! ✅ 119 = ambulance & fire. 110 = police. Important numbers!',
];
const wrongMessages = [
  'ざんねん…Not quite. The patient describes symptoms → おなかが痛いです。(C)',
  'ざんねん…食後 means AFTER meals, 3 times a day. Answer is (C).',
  'ざんねん…For moving-in you need your 在留カード and passport. Answer is (A).',
  'ざんねん…もう一度 = one more time. ゆっくり = slowly. Answer is (B).',
  'ざんねん…〜ていただけますか is a polite request to someone. Answer is (D).',
  'ざんねん…救急・火事 is 119. Police is 110. Answer is (C).',
];

function answerQuiz(btn, choice, qIdx) {
  const card = btn.closest('.quiz-card');
  if (card.dataset.answered) return;
  card.dataset.answered = 'true';

  const correct = parseInt(card.dataset.answer);
  const opts = card.querySelectorAll('.quiz-opt');
  opts.forEach((o, i) => {
    o.classList.add('disabled');
    if (i === correct) o.classList.add('correct');
    else if (i === choice && choice !== correct) o.classList.add('wrong');
  });

  const fb = document.getElementById('feedback-' + qIdx);
  if (choice === correct) {
    quizScore++;
    fb.className = 'quiz-feedback correct';
    fb.textContent = correctMessages[qIdx];
  } else {
    fb.className = 'quiz-feedback wrong';
    fb.textContent = wrongMessages[qIdx];
  }

  quizAnswered++;
  document.getElementById('score-text').textContent = quizScore + ' / ' + quizAnswered;
  document.getElementById('progress-bar').style.width = (quizAnswered / totalQ * 100) + '%';

  if (quizAnswered === totalQ) {
    const bar = document.getElementById('quiz-score-bar');
    document.getElementById('final-score').textContent = quizScore;
    bar.classList.add('visible');
    setTimeout(() => bar.classList.remove('visible'), 4000);
  }
}

// ── REGION SELECTOR ────────────────────
function showRegion(id, btn) {
  btn.closest('div').querySelectorAll('.region-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.region-info').forEach(r => r.classList.remove('active'));
  const el = document.getElementById('region-' + id);
  if (el) el.classList.add('active');
}

function resetQuiz() {  quizScore = 0; quizAnswered = 0;
  document.getElementById('score-text').textContent = '0 / 0';
  document.getElementById('progress-bar').style.width = '0%';
  document.querySelectorAll('.quiz-card').forEach(card => {
    delete card.dataset.answered;
    card.querySelectorAll('.quiz-opt').forEach(o => {
      o.className = 'quiz-opt';
    });
    card.querySelectorAll('.quiz-feedback').forEach(f => {
      f.className = 'quiz-feedback';
      f.textContent = '';
    });
  });
  document.getElementById('quiz-score-bar').classList.remove('visible');
}
</script>
</body>
</html>
